# =============================================================================
# Arkheion Frontend Environment Configuration
# Copy to .env (NOT .env.local — we use standard .env for Docker)
# =============================================================================

# Public API base URL — accessible from the browser
# In production, this should be your domain + /api/v1
PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Internal API base URL — used by SvelteKit server-side rendering (SSR)
# In Docker, this is the backend container name
INTERNAL_API_BASE_URL=http://arkheion-backend:8080/api/v1

# API key the frontend uses to authenticate with the backend
FRONTEND_API_KEY=changeme_generate_a_real_key_here

# Port the SvelteKit Node.js server listens on
PORT=3000
HOST=0.0.0.0
