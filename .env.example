# =============================================================================
# Arkheion Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend — General
# -----------------------------------------------------------------------------

# Port the Go backend listens on (inside Docker: always 8080)
BACKEND_PORT=8080

# Comma-separated list of API keys (hashed at startup).
# Generate with: openssl rand -hex 32
# In production, use a secrets manager instead.
ARKHEION_API_KEYS=changeme_generate_a_real_key_here

# Allowed CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arkheion
POSTGRES_USER=arkheion
POSTGRES_PASSWORD=changeme_strong_password_here

# Full connection string (used by backend and migrate script)
DATABASE_URL=postgres://arkheion:changeme_strong_password_here@postgres:5432/arkheion?sslmode=disable

# Connection pool settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=30

# -----------------------------------------------------------------------------
# Meilisearch
# -----------------------------------------------------------------------------

MEILISEARCH_URL=http://meilisearch:7700

# Master key — change this in production
MEILISEARCH_MASTER_KEY=changeme_meilisearch_master_key

# Index name for books
MEILISEARCH_BOOKS_INDEX=books

# -----------------------------------------------------------------------------
# Apache Tika
# -----------------------------------------------------------------------------

TIKA_URL=http://tika:9998

# Timeout for Tika text extraction requests (seconds)
TIKA_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_secret_here
MINIO_BUCKET=arkheion
MINIO_USE_SSL=false

# When running behind a reverse proxy, set this to the public URL
# used to generate cover art URLs in API responses.
MINIO_PUBLIC_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Frontend (SvelteKit)
# -----------------------------------------------------------------------------

# Public API base URL (accessible from the browser)
PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Internal API base URL (used by SvelteKit server-side rendering)
INTERNAL_API_BASE_URL=http://arkheion-backend:8080/api/v1

# The API key the frontend uses (one of the keys in ARKHEION_API_KEYS)
FRONTEND_API_KEY=changeme_generate_a_real_key_here

# Port the SvelteKit server listens on
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------

# Default HMAC secret for webhook signatures (per-webhook secrets override this)
WEBHOOK_DEFAULT_SECRET=changeme_webhook_hmac_secret

# Number of delivery retries on failure
WEBHOOK_MAX_RETRIES=3

# Retry backoff: initial delay in seconds (doubles each retry)
WEBHOOK_RETRY_INITIAL_DELAY_SECONDS=5

# Request timeout for webhook delivery (seconds)
WEBHOOK_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# External APIs (optional — used for ISBN lookup)
# -----------------------------------------------------------------------------

# Google Books API key (optional — OpenLibrary works without a key)
# Get one at: https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=

# OpenLibrary does not require an API key.
OPENLIBRARY_BASE_URL=https://openlibrary.org
GOOGLE_BOOKS_BASE_URL=https://www.googleapis.com/books/v1
